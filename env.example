# Ollama
OLLAMA_URL=http://localhost:11434/api/chat
OLLAMA_MODEL=qwen2.5:7b

# Generation
MAX_TOKENS=300

# Retrieval
TOP_K=5
RETRIEVAL_TOP_N=20
MIN_RETRIEVAL_SCORE=0.3
BM25_ALPHA=0.5
CHUNKS_FILE=chunks.json
INDEX_FILE=faiss.index
EMBED_MODEL=ncbi/MedCPT-Article-Encoder
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Force mock passages (integration tests / no index yet)
USE_MOCK_RETRIEVER=0

# Container only: run `python -m retriever.retriever` on startup if indexes missing (needs outbound network)
BUILD_RETRIEVAL_INDEX=0

# Faithfulness / iterative retrieval
FAITHFULNESS_THRESHOLD=0.3
ABLATION_STRICT_NLI=0.75
MAX_ITER=2